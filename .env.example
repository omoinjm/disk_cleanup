# safewipe Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# This file configures safewipe behavior without modifying source code.
# All settings are optional; defaults are used if not specified.
#
# For production deployments, copy this to .env and adjust as needed.
# NEVER commit .env with sensitive data to version control.

# ─────────────────────────────────────────────────────────────────────────────
# Logging Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Directory where safewipe operation logs are stored
# Logs are organized as: SAFEWIPE_LOG_DIR/safewipe-YYYY-MM-DD.log (JSON lines format)
# Default: ~/.safewipe/logs
SAFEWIPE_LOG_DIR=~/.safewipe/logs

# Number of days to retain operation logs before automatic cleanup
# Set to 0 to disable cleanup (retain logs indefinitely)
# Default: 30
SAFEWIPE_LOG_RETENTION_DAYS=30

# Should sensitive data (device serials, usernames) be included in logs?
# Set to 'true' for debugging; set to 'false' for privacy
# Default: false
SAFEWIPE_LOG_SENSITIVE_DATA=false

# ─────────────────────────────────────────────────────────────────────────────
# Mounting Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Base directory for auto-mounting formatted devices
# Mount point will be: SAFEWIPE_MOUNT_BASE/<username>/<device-label>
# Default: /media
SAFEWIPE_MOUNT_BASE=/media

# Prefix used for auto-generated mount point labels when mounting devices
# Example: If set to 'usb', device mounted as /media/user/usb-001
# Default: safewipe
SAFEWIPE_MOUNT_LABEL_PREFIX=safewipe

# Automatically mount device after successful formatting
# Default: true
SAFEWIPE_AUTO_MOUNT=true

# ─────────────────────────────────────────────────────────────────────────────
# Wipe Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Block size for I/O operations during wipe (bytes)
# Larger = faster (more data per read/write) but uses more memory
# Smaller = slower but less memory usage
# Default: 4194304 (4 MiB)
# Typical range: 1 MiB (1048576) to 128 MiB (134217728)
SAFEWIPE_BLOCK_SIZE=4194304

# Size of header and footer written during quick wipe method (bytes)
# Quick wipe only overwrites first N and last N bytes, leaving middle untouched
# Used for USB drives where only header is at risk
# Default: 10485760 (10 MiB)
SAFEWIPE_QUICK_WIPE_SIZE=10485760

# Run wipe verification automatically after wipe completion
# Verification samples random sectors to confirm wipe success
# Set to 'true' for extra safety; set to 'false' to skip (faster)
# Default: false
SAFEWIPE_VERIFY_BY_DEFAULT=false

# ─────────────────────────────────────────────────────────────────────────────
# Verification Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Number of random sectors to sample during wipe verification
# More samples = higher confidence but takes longer
# Default: 8
SAFEWIPE_VERIFY_SAMPLE_COUNT=8

# Size of each verification sample (bytes)
# Default: 524288 (512 KiB)
SAFEWIPE_VERIFY_SAMPLE_SIZE=524288

# ─────────────────────────────────────────────────────────────────────────────
# Device Detection Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Timeout in seconds when waiting for newly created partitions to appear
# After creating a partition with parted, the system needs time to see /dev/sdbN
# Default: 5
SAFEWIPE_PARTITION_TIMEOUT=5

# Number of retries when waiting for partition to appear
# Will retry up to PARTITION_RETRIES times with PARTITION_TIMEOUT between each
# Default: 10
SAFEWIPE_PARTITION_RETRIES=10
